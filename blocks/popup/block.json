{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "swish/popup",
	"title": "Swish Popup",
	"category": "widgets",
	"icon": "megaphone",
	"description": "Container for a Swish lead-magnet popup. Add image, heading, paragraph, columns and an AC form inside.",
	"textdomain": "swish-active-campaign",
	"supports": {
		"html": false,
		"multiple": false,
		"reusable": false,
		"inserter": true,
		"color": { "background": true, "text": true }
	},
	"attributes": {
		"accentColor":    { "type": "string", "default": "#ffba00" },
		"successMessage": { "type": "string", "default": "Thanks! Check your inbox." },
		"imageId":        { "type": "number", "default": 0 },
		"imageUrl":       { "type": "string", "default": "" },
		"imageAlt":       { "type": "string", "default": "" },
		"layout":         { "type": "string", "default": "stack" },
		"imageOpacity":   { "type": "number", "default": 0.4 },
		"width":          { "type": "number", "default": 460 },
		"padding":        { "type": "object", "default": null },
		"imageHeight":    { "type": "number", "default": 0 },
		"focalPoint":     { "type": "object", "default": { "x": 0.5, "y": 0.5 } }
	},
	"editorScript": "file:./index.js",
	"style":        "file:./style.css",
	"editorStyle":  "file:./editor.css",
	"render":       "file:./render.php"
}
